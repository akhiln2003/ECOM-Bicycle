<%- include('../layout/user/header.ejs') %>
    <%- include('../layout/user/navbar.ejs') %>

        <div class="container">
            <div class="main-body">

                <!-- Breadcrumb Section -->
                <section class="breadcrumb-section">
                    <div class="container">
                        <div class="row">
                            <div class="col-12" style="margin-top: 100px; margin-bottom: 40px;">
                                <h2>Edit Profile</h2>
                                <div class="breadcrumb-text">
                                    <a style="color: black; text-decoration: none; " href="/">Home</a> >
                                    <span>Edit Profile</span>
                                    <hr>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="row gutters-sm">

                    <div class="col-md-8" style="margin-left: 11rem;margin-bottom: 3rem;">
                        <div class="card mb-3">
                            <div class="card-body">
                                <% if (messages.error) { %>
                                    <div class="alert alert-danger d-flex align-items-center  " role="alert"
                                        id="error-alert">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                            fill="currentColor"
                                            class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2 "
                                            viewBox="0 0 16 16" role="img" aria-label="Warning:">
                                            <path
                                                d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                                        </svg>
                                        <div>
                                            <strong>Hey !</strong>
                                            <%= messages.error %>
                                        </div>
                                    </div>
                                    <% } %>
                                        <!-- Edit Profile Form -->
                                        <form action="" method="POST">
                                            <div class="mb-3">
                                                <label for="editName" class="form-label">Full Name:</label>
                                                <input type="hidden" name="id" value="<%= user._id %>">
                                                <input type="text" class="form-control" id="editName" name="editName"
                                                    value="<%= user.name %>" required>
                                            </div>
                                            <div class="mb-3">
                                                <label for="editEmail" class="form-label">Email:</label>
                                                <input type="email" class="form-control" id="editEmail" name="editEmail"
                                                    value="<%= user.email %>" required>
                                                <small class="text-muted d-block mt-2">If you change your email, you'll need to verify it with an OTP.</small>
                                                <small class="text-danger d-none mt-1" id="emailError"></small>
                                                <small class="text-success d-none mt-1" id="emailSuccess"></small>
                                            </div>
                                            <div class="mb-3 text-end">
                                                <button type="button" class="btn btn-secondary"
                                                    onclick="window.location='/profile'">Cancel</button>
                                                <button type="submit" class="btn btn-primary" id="saveBtn">Save Changes</button>
                                            </div>
                                        </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('../layout/user/footbar.ejs') %>
            <%- include('../layout/user/footer.ejs') %>

            <script>
                const currentEmail = '<%= user.email %>';
                const userId = '<%= user._id %>';
                const editEmailInput = document.getElementById('editEmail');
                const emailError = document.getElementById('emailError');
                const emailSuccess = document.getElementById('emailSuccess');
                const saveBtn = document.getElementById('saveBtn');
                let isEmailValid = true;

                // Check email availability as user types
                editEmailInput.addEventListener('change', async function() {
                    const newEmail = this.value.trim();

                    // If email hasn't changed, hide messages and allow submit
                    if (newEmail.toLowerCase() === currentEmail.toLowerCase()) {
                        emailError.classList.add('d-none');
                        emailSuccess.classList.add('d-none');
                        isEmailValid = true;
                        return;
                    }

                    // If email field is empty, hide messages
                    if (!newEmail) {
                        emailError.classList.add('d-none');
                        emailSuccess.classList.add('d-none');
                        isEmailValid = true;
                        return;
                    }

                    try {
                        const response = await fetch('/checkEmailAvailability', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ email: newEmail, userId: userId })
                        });

                        const data = await response.json();

                        if (data.available) {
                            emailError.classList.add('d-none');
                            emailSuccess.classList.remove('d-none');
                            emailSuccess.textContent = '✓ Email is available';
                            isEmailValid = true;
                        } else {
                            emailSuccess.classList.add('d-none');
                            emailError.classList.remove('d-none');
                            emailError.textContent = '✗ ' + data.message;
                            isEmailValid = false;
                        }
                    } catch (error) {
                        console.error('Error checking email:', error);
                        emailError.classList.remove('d-none');
                        emailError.textContent = 'Error checking email availability';
                        isEmailValid = false;
                    }
                });

                // Validate on form submit
                document.querySelector('form').addEventListener('submit', function(e) {
                    const newEmail = editEmailInput.value.trim();

                    // If email did not change, allow submit
                    if (newEmail.toLowerCase() === currentEmail.toLowerCase()) {
                        return true;
                    }

                    // If email changed but not valid, prevent submit
                    if (!isEmailValid) {
                        e.preventDefault();
                        emailError.classList.remove('d-none');
                        return false;
                    }
                });
            </script>